{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "yw-look",
  "version": "0.1.7",
  "identifier": "com.yohawing.ywlook",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "yw-look",
        "width": 1440,
        "height": 960,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "dangerousInsecureTransportProtocol": true,
      "endpoints": [],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJCQ0M2RDM1Qzc5RkE4REEKUldUYXFKL0hOVzNNSzNMbmRwUXpPazlRa3NZRzJtTVlKSVFvVHRDK05CellrYXZSRGJlTGR6elYK",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "macOS": {
      "entitlements": "Entitlements.plist",
      "signingIdentity": "-"
    },
    "fileAssociations": [
      {
        "ext": [
          "glb",
          "gltf",
          "fbx",
          "obj",
          "ply",
          "stl",
          "dae",
          "usd",
          "usda",
          "usdc",
          "usdz"
        ],
        "name": "yw-look Model Asset",
        "description": "3D model asset opened by yw-look"
      },
      {
        "ext": ["png", "jpg", "jpeg", "tga", "dds", "ktx2", "hdr", "exr"],
        "name": "yw-look Texture Asset",
        "description": "Texture asset opened by yw-look"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
