{
  "name": "yw-look",
  "private": true,
  "version": "0.1.9",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:desktop": "npm run build && npm run tauri build",
    "bundle:win": "npm run tauri build -- --bundles nsis,msi",
    "bundle:mac": "npm run tauri build -- --bundles app,dmg",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json && cargo check --manifest-path src-tauri/Cargo.toml",
    "check": "npm run lint && npm run format:check && npm run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:batch": "node scripts/batch-load-test.mjs",
    "test:fixtures": "node scripts/fixture-regression.mjs",
    "test:integration": "node scripts/run-selftest.mjs",
    "test:visual": "node scripts/visual-regression.mjs",
    "test:viewport-snapshot": "node scripts/viewport-snapshot.mjs",
    "test:viewport-snapshot:update": "node scripts/viewport-snapshot.mjs --update-snapshot",
    "samples:fetch": "node samples/private/fetch.mjs",
    "bench:load": "node scripts/run-load-bench.mjs",
    "bench:load:baseline": "node scripts/compare-load-bench.mjs --write-baseline artifacts/bench/load-baseline.json",
    "bench:load:compare": "node scripts/compare-load-bench.mjs --baseline artifacts/bench/load-baseline.json",
    "shot": "node scripts/run-shot.mjs shot",
    "shot:check": "node scripts/run-shot.mjs check",
    "update:local:prepare": "node scripts/prepare-local-update-feed.mjs",
    "update:local:serve": "node scripts/serve-local-update-feed.mjs",
    "tauri": "tauri",
    "prepare": "husky"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.8.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "three": "^0.179.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.1.3",
    "vitest": "^4.1.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,html}": [
      "prettier --write"
    ]
  }
}
